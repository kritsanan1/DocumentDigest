# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/database_name
PGHOST=localhost
PGPORT=5432
PGUSER=username
PGPASSWORD=password
PGDATABASE=database_name

# Thai Government Digital Identity APIs
# NDID (National Digital ID) - Blockchain-based identity verification
NDID_API_KEY=your_ndid_api_key_here
NDID_CLIENT_ID=your_ndid_client_id_here
NDID_CLIENT_SECRET=your_ndid_client_secret_here
NDID_BASE_URL=https://api.ndid.co.th/v1

# DOPA (Department of Provincial Administration) - Civil Registration
DOPA_API_KEY=your_dopa_api_key_here
DOPA_CLIENT_ID=your_dopa_client_id_here
DOPA_BASE_URL=https://api.dopa.go.th/v1

# ThaID Mobile App Integration
THAID_API_KEY=your_thaid_api_key_here
THAID_CLIENT_ID=your_thaid_client_id_here
THAID_BASE_URL=https://thaid.ndid.co.th/v1

# Sandbox Environment (for testing)
USE_SANDBOX=true
NDID_SANDBOX_URL=https://sandbox-api.ndid.co.th/v1
DOPA_SANDBOX_URL=https://sandbox-api.dopa.go.th/v1
THAID_SANDBOX_URL=https://sandbox-thaid.ndid.co.th/v1

# Application Configuration
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=http://localhost:5000

# WebSocket Configuration
WS_PORT=5001
WS_HEARTBEAT_INTERVAL=30000

# Optional: Webhook URLs for verification callbacks
NDID_CALLBACK_URL=https://your-app-domain.com/api/auth/ndid/callback
DOPA_CALLBACK_URL=https://your-app-domain.com/api/auth/dopa/callback
THAID_CALLBACK_URL=https://your-app-domain.com/api/auth/thaid/callback

# Optional: ThaID App Configuration
THAID_APP_NAME=อบต.วังสามหมอ
THAID_APP_LOGO_URL=https://your-app-domain.com/assets/logo.png